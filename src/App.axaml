<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="YtDlpGui.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />

        <!-- Global custom styles -->
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#3478F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="50"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A8AFF"/>
        </Style>
        <Style Selector="Button.accent:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <Style Selector="Button.outlined">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#3A3A3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="50"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>
        <Style Selector="Button.outlined:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2C"/>
            <Setter Property="BorderBrush" Value="#4A4A4C"/>
        </Style>

        <Style Selector="Button.text">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
        <Style Selector="Button.text:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1A1A1A"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#2A2A2C"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#2A2A2C"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A3C"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#3478F6"/>
        </Style>

        <Style Selector="ToggleSwitch">
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="MinHeight" Value="6"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="#2A2A2C"/>
            <Setter Property="Foreground" Value="#3478F6"/>
        </Style>
    </Application.Styles>
</Application>
